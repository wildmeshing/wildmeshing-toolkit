[
  {
    "doc": "",
    "pointer": "/",
    "type": "object",
    "required": ["application", "input"],
    "optional": [
      "output",
      "input_dir",
      "tag_selection",
      "fill_tags",
      "radius_rel",
      "radius",
      "DEBUG_output",
      "write_surface",
      "save_vtu",
      "log_file",
      "report"
    ]
  },
  {
    "pointer": "/application",
    "type": "string",
    "options": ["manifold_extraction"],
    "doc": "Application name must be manifold_extraction."
  },
  {
    "pointer": "/input",
    "type": "string",
    "doc": "Tetrahedral input mesh."
  },
  {
    "pointer": "/output",
    "type": "string",
    "default": "out",
    "doc": "Output file name (without extension)."
  },
  {
    "pointer": "/input_dir",
    "type": "string",
    "default": "",
    "doc": "Directory where the input files are located. This is injected by the application and should not be set by the user."
  },
  {
    "pointer": "/tag_selection",
    "type": "string",
    "default": "tag_0",
    "doc": "Tag selection, the boundary of which is taken to be the input surface to make manifold. Only the & operator is allowed here."
  },
  {
    "pointer": "/fill_tags",
    "type": "list",
    "default": [],
    "doc": "Tag set to fill non-manifold offsets with. [] for ambient."
  },
  {
    "pointer": "/fill_tags/*",
    "type": "string",
    "doc": "A tag."
  },
  {
    "pointer": "/radius_rel",
    "type": "float",
    "default": 1e-2,
    "doc": "Radius to offset around non manifold components, relative to bounding box diagonal."
  },
  {
    "pointer": "/radius",
    "type": "float",
    "default": -1.0,
    "doc": "Radius to offset around non manifold components. If < 0, this is set by radius_rel"
  },
  {
    "pointer": "/DEBUG_output",
    "type": "bool",
    "default": false,
    "doc": "Write the tet mesh as out_{}.vtu after every operation."
  },
  {
    "pointer": "/save_vtu",
    "type": "bool",
    "default": false,
    "doc": "Save .vtu of output mesh"
  },
  {
    "pointer": "/write_surface",
    "type": "bool",
    "default": false,
    "doc": "Write the output surface (OBJ) after manifold extraction."
  },
  {
    "pointer": "/log_file",
    "type": "string",
    "default": "",
    "doc": "Logs are not just printed on the terminal but also saved in this file."
  },
  {
    "pointer": "/report",
    "type": "string",
    "default": "",
    "doc": "A JSON file that stores information about the result and the method execution, e.g., runtime."
  }
]
